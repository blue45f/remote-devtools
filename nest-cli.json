{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/remote-platform-internal/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/remote-platform-internal/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/remote-platform-internal",
  "projects": {
    "remote-platform-internal": {
      "type": "application",
      "root": "apps/remote-platform-internal",
      "entryFile": "main",
      "sourceRoot": "apps/remote-platform-internal/src",
      "compilerOptions": {
        "tsConfigPath": "apps/remote-platform-internal/tsconfig.app.json"
      }
    },
    "remote-platform-external": {
      "type": "application",
      "root": "apps/remote-platform-external",
      "entryFile": "main",
      "sourceRoot": "apps/remote-platform-external/src",
      "compilerOptions": {
        "tsConfigPath": "apps/remote-platform-external/tsconfig.app.json"
      }
    },
    "entity": {
      "type": "library",
      "root": "libs/entity",
      "entryFile": "index",
      "sourceRoot": "libs/entity/src",
      "compilerOptions": {
        "tsConfigPath": "libs/entity/tsconfig.lib.json"
      }
    },
    "constants": {
      "type": "library",
      "root": "libs/constants",
      "entryFile": "index",
      "sourceRoot": "libs/constants/src",
      "compilerOptions": {
        "tsConfigPath": "libs/constants/tsconfig.lib.json"
      }
    }
  }
}
