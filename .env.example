# ============================================
# Remote Debug Tools - 환경변수 설정 템플릿
# ============================================
# 이 파일을 복사하여 .env.local로 저장한 후
# 실제 값으로 수정하세요.
#
# cp .env.example apps/remote-platform-external/src/.env.local
# cp .env.example apps/remote-platform-internal/src/.env.local
# ============================================

# ============================================
# 서버 설정
# ============================================
# 실행 환경 (development, production, test)
NODE_ENV=development

# 앱 환경 설정 (development, beta, production)
APP_ENV=development

# 서버 포트
# Internal 서버: 3000
# External 서버: 3001
PORT=3000

# ============================================
# 데이터베이스 설정 (PostgreSQL)
# ============================================
# 데이터베이스 호스트 주소
# Docker Compose 사용 시: postgres
# 로컬 설치 시: localhost
DB_HOST=localhost

# 데이터베이스 포트 (기본값: 5432)
DB_PORT=5432

# 데이터베이스 사용자명
DB_USERNAME=myuser

# 데이터베이스 비밀번호
DB_PASSWORD=mypassword

# 데이터베이스 이름
DB_DATABASE=mydb

# ============================================
# AWS S3 설정 (선택사항)
# ============================================
# 세션 데이터 백업에 사용됩니다.
# 설정하지 않으면 로컬 파일 시스템을 사용합니다.

# AWS 리전 (예: ap-northeast-2)
AWS_REGION=ap-northeast-2

# S3 버킷 이름
AWS_S3_BUCKET=your-s3-bucket-name

# AWS 인증 정보
# 로컬 개발: 빈 값으로 두거나 AWS CLI 프로필 사용
# 프로덕션: IAM 역할 또는 환경 변수 사용 권장
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ============================================
# CORS 설정
# ============================================
# 허용할 도메인 목록 (쉼표로 구분, 프로토콜 제외)
# 예: example.com,myapp.com,staging.myapp.com
# 빈 값이면 localhost만 허용
CORS_ALLOWED_ORIGINS=

# ============================================
# SDK 설정
# ============================================
# SDK에서 사용할 서버 주소 (프로덕션 빌드용)
# VITE_INTERNAL_HOST=https://internal.example.com
# VITE_INTERNAL_WS=wss://internal.example.com
# VITE_EXTERNAL_HOST=https://external.example.com
# VITE_EXTERNAL_WS=wss://external.example.com

# ============================================
# Jira 연동 (선택사항)
# ============================================
# Jira 티켓 자동 생성 기능에 사용됩니다.

# Jira 서버 주소 (Atlassian Cloud)
# 예: https://your-domain.atlassian.net
JIRA_HOST=https://your-domain.atlassian.net

# Jira 로그인 이메일
JIRA_USERNAME=your-email@example.com

# Jira API 토큰
# 생성 방법: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token

# 기본 Jira 프로젝트 키
JIRA_PROJECT=YOUR_PROJECT_KEY

# ============================================
# Slack 연동 (선택사항)
# ============================================
# 세션 생성 알림 기능에 사용됩니다.

# Slack Bot OAuth 토큰
# 생성 방법: https://api.slack.com/apps에서 앱 생성 후 토큰 발급
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# 알림을 보낼 Slack 채널 ID
# 채널 ID 확인: 채널 우클릭 > 링크 복사 > URL에서 ID 추출
SLACK_CHANNEL_ID=C0000000000

# ============================================
# Google Sheets 연동 (선택사항)
# ============================================
# 티켓 템플릿 관리에 사용됩니다.

# Google 서비스 계정 이메일
# 생성 방법: Google Cloud Console > IAM > 서비스 계정
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Google 서비스 계정 비공개 키 (줄바꿈은 \n으로)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Google 스프레드시트 ID
# URL에서 추출: https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# ============================================
# Workflow API (선택사항)
# ============================================
# 외부 워크플로우 시스템 연동에 사용됩니다.
WORKFLOW_API_URL=http://localhost:3001

# ============================================
# 기타 설정
# ============================================
# External 서버 주소 (스크린샷 생성 등에 사용)
EXTERNAL_HOST=http://localhost:3001

# Internal 서버 주소
INTERNAL_HOST=http://localhost:3000
