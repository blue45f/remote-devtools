{
  "name": "remote-debug-tools",
  "version": "1.0.0",
  "description": "Remote debugging platform for web applications with recording and replay capabilities",
  "author": "",
  "private": false,
  "license": "MIT",
  "files": [
    "dist",
    "Dockerfile",
    "ecosystem.config.js",
    "assets",
    "devtools-frontend",
    "client/dist",
    "sdk/dist",
    ".dockerignore"
  ],
  "scripts": {
    "clean": "sh ./scripts/cleaner.sh",
    "typecheck": "tsc --noEmit && cd figma-plugin && npx tsc --noEmit",
    "build:internal": "nest build remote-platform-internal",
    "build:external": "nest build remote-platform-external",
    "build:all": "pnpm run build:internal && pnpm run build:external",
    "start:container": "pm2-runtime start ecosystem.config.js",
    "start:internal": "nest start remote-platform-internal",
    "start:internal:dev": "nest start remote-platform-internal --watch",
    "start:external": "nest start remote-platform-external",
    "start:external:dev": "nest start remote-platform-external --watch",
    "compose": "docker-compose up",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint apps/ libs/ --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "devtools:dev": "browser-sync start --proxy 'localhost:3000' --files 'devtools-frontend/**/*' --port 3002 --no-open --no-notify"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-ws": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@types/express": "^5.0.6",
    "axios": "^1.14.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "devtools-protocol": "^0.0.1340018",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "mime": "^4.1.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "pm2": "^6.0.14",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^2.0.9",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^11.1.17",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.15",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^3.2.4",
    "browser-sync": "^3.0.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.1.0"
}
