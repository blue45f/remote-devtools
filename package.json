{
  "name": "remote-debug-tools",
  "version": "1.0.0",
  "description": "Remote debugging platform for web applications with recording and replay capabilities",
  "author": "",
  "private": false,
  "license": "MIT",
  "files": [
    "dist",
    "Dockerfile",
    "ecosystem.config.js",
    "assets",
    "devtools-frontend",
    "client/dist",
    "sdk/dist",
    ".dockerignore"
  ],
  "scripts": {
    "clean": "sh ./scripts/cleaner.sh",
    "typecheck": "tsc --noEmit && cd figma-plugin && npx tsc --noEmit",
    "build:internal": "nest build remote-platform-internal",
    "build:external": "nest build remote-platform-external",
    "build:all": "pnpm run build:internal && pnpm run build:external",
    "start:container": "pm2-runtime start ecosystem.config.js",
    "start:internal": "nest start remote-platform-internal",
    "start:internal:dev": "nest start remote-platform-internal --watch",
    "start:admin": "ts-node apps/remote-platform-internal/src/main-admin.ts",
    "start:admin:dev": "nodemon --exec ts-node apps/remote-platform-internal/src/main-admin.ts",
    "start:external": "nest start remote-platform-external",
    "start:external:dev": "nest start remote-platform-external --watch",
    "compose": "docker-compose up",
    "test:google-sheets": "ts-node apps/remote-platform-external/src/modules/google-sheets/google-sheets.service.test.ts",
    "devtools:dev": "browser-sync start --proxy 'localhost:3000' --files 'devtools-frontend/**/*' --port 3002 --no-open --no-notify"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.986.0",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/platform-ws": "^11.1.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.0",
    "@types/express": "^5.0.0",
    "@types/har-format": "^1.2.16",
    "@types/jira-client": "^7.1.9",
    "axios": "^1.13.5",
    "chrome-har": "^0.13.5",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "devtools-protocol": "^0.0.1340018",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.5.0",
    "googleapis": "^171.4.0",
    "image-to-base64": "^2.2.0",
    "jimp": "^1.6.0",
    "jira-client": "^8.2.2",
    "mime": "^4.1.0",
    "pg": "^8.18.0",
    "playwright": "^1.58.0",
    "pm2": "^5.4.3",
    "puppeteer": "^24.37.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^2.0.6",
    "uuid": "^10.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^11.0.0",
    "@types/chrome-remote-interface": "^0.31.14",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.4",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "browser-sync": "^3.0.4",
    "eslint": "^9.20.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^29.7.0",
    "prettier": "^3.7.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@remote-platform/entity(|/.*)$": "<rootDir>/libs/entity/src/$1",
      "^@remote-platform/constants(|/.*)$": "<rootDir>/libs/constants/src/$1"
    }
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.1.0"
}
