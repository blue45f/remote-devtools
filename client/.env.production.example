# ──────────────────────────────────────────────────────────────────────
# Public demo build (Vercel)
# ──────────────────────────────────────────────────────────────────────
# When this is set the client never reaches a backend — apiFetch returns
# seed data so visitors can explore the entire UI without infrastructure.
VITE_FORCE_DEMO=true

# Real production build (your own deployment)
# Comment the line above and point these at the running backends instead.
# VITE_HOST=https://api.your-domain.com
# VITE_WS_HOST=wss://ws.your-domain.com
